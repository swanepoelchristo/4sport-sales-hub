# Example nginx reverse proxy for the 4SPORT dashboard.
# Place under /etc/nginx/sites-available/4sport and symlink into sites-enabled.
# Obtain TLS with: sudo certbot --nginx -d dashboard.4sport.co.za

server {
    listen 80;
    server_name dashboard.4sport.co.za;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name dashboard.4sport.co.za;

    ssl_certificate     /etc/letsencrypt/live/dashboard.4sport.co.za/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dashboard.4sport.co.za/privkey.pem;

    client_max_body_size 20m;

    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Upgrade           $http_upgrade;
        proxy_set_header   Connection        "upgrade";
        proxy_read_timeout 60s;
    }
}
