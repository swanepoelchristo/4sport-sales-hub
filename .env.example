# These values are auto-populated by Lovable Cloud during development.
# For self-hosting on your Ubuntu server, fill these in with your Supabase project values.

VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT-REF

# Server-only (for the seed script). Never expose to the browser.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# WhatsApp Cloud API webhook verification token. Server-only.
WHATSAPP_VERIFY_TOKEN=change-me-to-a-long-random-string
